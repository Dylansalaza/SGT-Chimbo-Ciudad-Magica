# =============================================================================
#  Frontend (React + Vite) — variables de producción
#  Copia como `.env.production` antes de compilar:  npm run build
# =============================================================================

# URL pública del backend Laravel, SIEMPRE terminando en /api.
#   - Si backend y frontend van en el mismo dominio:  https://tudominio.com/api
#   - Si el backend va en un subdominio:               https://api.tudominio.com/api
VITE_API_URL=https://<tu-dominio>/api
