# =============================================================================
#  PLANTILLA DE PRODUCCIÓN — SGT Chimbo
#  Copia este archivo como `.env` EN EL SERVIDOR y rellena los valores <...>.
#  NUNCA subas el .env real a Git (ya está en .gitignore).
#
#  Pasos mínimos tras subir el código:
#    1) composer install --no-dev --optimize-autoloader
#    2) php artisan key:generate        (genera APP_KEY)
#    3) rellena los <...> de abajo
#    4) php artisan migrate --force
#    5) php artisan storage:link
#    6) php artisan config:cache route:cache view:cache
# =============================================================================

APP_NAME="SGT Chimbo"
APP_ENV=production
# Se genera con: php artisan key:generate
APP_KEY=
# ⚠️ En producción SIEMPRE false (con true se filtran rutas y datos internos).
APP_DEBUG=false
# Tu dominio con https. Si aún no tienes, pon el subdominio del hosting.
APP_URL=https://<tu-dominio>

# Idioma del portal
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

# Solo errores en el log de producción (no "debug").
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Coste de hash de contraseñas (12 es un buen equilibrio).
BCRYPT_ROUNDS=12

# --- Frontend (React) ---------------------------------------------------------
# Origen(es) del frontend permitidos por CORS. Separa varios con comas.
FRONTEND_URLS=https://<tu-dominio>

# --- Base de datos (PostgreSQL) ----------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=<host-de-tu-bd>
DB_PORT=5432
DB_DATABASE=<nombre-bd>
DB_USERNAME=<usuario-bd>
DB_PASSWORD=<password-bd-fuerte>

# --- Sesión / cookies seguras -------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
# true = la cookie de sesión SOLO viaja por HTTPS (obligatorio en producción).
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
# Deja SESSION_DOMAIN vacío salvo que compartas cookies entre subdominios.
SESSION_DOMAIN=

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# --- Correo (recuperación de contraseña) — Gmail con app-password ------------
# Genera la app-password (16 caracteres, sin espacios) en:
#   https://myaccount.google.com/apppasswords
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=<tu-correo@gmail.com>
MAIL_PASSWORD=<app-password-de-16-caracteres>
MAIL_FROM_ADDRESS="<tu-correo@gmail.com>"
MAIL_FROM_NAME="SGT Chimbo"

# --- Asistente IA (chatbot) — Groq -------------------------------------------
# Genera tu clave gratis en https://console.groq.com/keys
GROQ_API_KEY=<tu-groq-api-key>
GROQ_MODEL=llama-3.1-8b-instant

# --- Microservicio de búsqueda por imagen (Python/Flask + CLIP) --------------
# URL INTERNA donde corre clip_service.py (mismo servidor/red privada).
CLIP_SERVICE_URL=http://127.0.0.1:5001
CLIP_SERVICE_TIMEOUT=30
# 🔐 Token compartido: DEFÍNELO en producción (una cadena larga y aleatoria) y
# ponlo también en el entorno del servicio Python (CLIP_AUTH_TOKEN). Así solo tu
# backend puede llamar a /search y /refresh del motor de IA.
#   Genera uno con: php artisan key:generate --show   (usa la parte tras "base64:")
CLIP_AUTH_TOKEN=<token-largo-aleatorio>
